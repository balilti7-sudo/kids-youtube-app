# Production (Vercel) when using Germany bridge behind Cloudflare quick tunnel.
# 1. On the server: powershell -File deploy/windows-server/start-cloudflare-tunnel.ps1
# 2. Copy the https://….trycloudflare.com URL from the log
# 3. Set in Vercel → Environment Variables → Production:
VITE_STREAM_API_BASE=https://YOUR_TUNNEL_HOST.trycloudflare.com

# Also set on the server in C:\ProgramData\SafeTube\bridge.env:
# PUBLIC_BRIDGE_ORIGIN=https://YOUR_TUNNEL_HOST.trycloudflare.com
# Then: Restart-Service SafeTubeBridge
