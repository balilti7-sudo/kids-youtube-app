# C:\ProgramData\SafeTube\bridge.env
#
# Production env for the SafeTube Media Bridge on the Windows server.
# Loaded by start-bridge.ps1 at service start.
#
# Install:
#   The installer copies this file to C:\ProgramData\SafeTube\bridge.env on first run.
#   To edit:  notepad C:\ProgramData\SafeTube\bridge.env
#   To apply: Restart-Service SafeTubeBridge
#
# NEVER commit a filled-in bridge.env to git — it contains secrets.

# --- core bridge config -------------------------------------------------------
PORT=3001
MEDIA_BRIDGE_HOST=0.0.0.0

# CORS: production frontend origin(s), comma-separated. Replace with your real Vercel domain.
MEDIA_BRIDGE_CORS_ORIGINS=https://www.safetube.co.il,https://safetube.co.il
# Or, for testing only, allow any origin (NOT recommended on a public IP):
# MEDIA_BRIDGE_CORS_ALLOW_ANY=1

# Public origin used inside HLS manifests. Set to your Cloudflare Tunnel URL (no trailing slash).
PUBLIC_BASE_URL=FIXME

# --- yt-dlp auth: PO token + visitor_data (rotated every 4h by Task Scheduler) -
# These two lines are MANAGED AUTOMATICALLY by refresh-pot.ps1.
# Leave them empty initially — the first scheduled task run will populate them.
YOUTUBE_PO_TOKEN=
YOUTUBE_VISITOR_DATA=

# --- yt-dlp cookies (Netscape cookies.txt exported from a signed-in browser) --
# Use forward slashes OR escape backslashes: C:\\Users\\... is fine for the bridge env loader.
YOUTUBE_COOKIES_FILE=FIXME_PATH_TO_COOKIES_TXT

# --- Supabase (required if REQUIRE_CONFIRMED_EMAIL_FOR_STREAM=1) --------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=FIXME
REQUIRE_CONFIRMED_EMAIL_FOR_STREAM=1

# --- Playback grant signing (generate with: -hex 32 worth of random bytes) ----
# In PowerShell:  -join ((1..32) | ForEach { '{0:x2}' -f (Get-Random -Max 256) })
MEDIA_BRIDGE_GRANT_SECRET=FIXME_GENERATE_LONG_RANDOM_SECRET
STREAM_GRANT_TTL_MS=900000

# --- Resend (optional: welcome email) -----------------------------------------
# RESEND_API_KEY=
# RESEND_FROM=SafeTube <support@safetube.co.il>
# MEDIA_BRIDGE_WELCOME_KEY=FIXME_match_VITE_MEDIA_BRIDGE_WELCOME_KEY

# --- Outbound: direct egress from the German Windows IP — no proxy ------------
OUTBOUND_PROXY_DISABLE=1

# --- yt-dlp tuning ------------------------------------------------------------
# YT_DLP_PRIMARY_EXTRACTOR_ARGS=youtube:player_client=web
# YT_DLP_PER_ATTEMPT_TIMEOUT_MS=30000
# OVERALL_RESOLVE_BUDGET_MS=120000
