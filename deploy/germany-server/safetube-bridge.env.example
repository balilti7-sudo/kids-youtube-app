# /etc/safetube-bridge.env
#
# Production env for the SafeTube Media Bridge on the Germany server.
# Loaded by safetube-bridge.service via EnvironmentFile=.
#
# Install:  sudo cp safetube-bridge.env.example /etc/safetube-bridge.env
#           sudo nano /etc/safetube-bridge.env   # fill in the FIXME values
#           sudo chmod 600 /etc/safetube-bridge.env
#           sudo chown root:root /etc/safetube-bridge.env
#
# NEVER commit a real /etc/safetube-bridge.env to git — it contains secrets.

# --- core bridge config -------------------------------------------------------
PORT=3001
MEDIA_BRIDGE_HOST=0.0.0.0

# CORS: production frontend origin(s), comma-separated. Replace with your real Vercel domain.
MEDIA_BRIDGE_CORS_ORIGINS=https://www.safetube.co.il,https://safetube.co.il
# Or, for testing only, allow any origin (NOT recommended on a public IP):
# MEDIA_BRIDGE_CORS_ALLOW_ANY=1

# Public origin used inside HLS manifests. Set to your Cloudflare Tunnel URL (no trailing slash).
# Example: https://safetube-bridge.trycloudflare.com
PUBLIC_BASE_URL=FIXME

# --- yt-dlp auth: PO token + visitor_data (rotated every 4h by the timer) -----
# These two lines are MANAGED AUTOMATICALLY by /usr/local/bin/refresh-yt-pot.sh.
# Leave them empty initially — the first systemctl start of safetube-pot-refresh
# will populate them. You can also paste a known-good pair to bootstrap.
YOUTUBE_PO_TOKEN=
YOUTUBE_VISITOR_DATA=

# Optional: Netscape cookies for yt-dlp (relative paths are under the bridge server/ dir).
YT_DLP_COOKIES_FILE=./youtube_cookies.txt

# --- Supabase (required if REQUIRE_CONFIRMED_EMAIL_FOR_STREAM=1) --------------
SUPABASE_ANON_KEY=FIXME
REQUIRE_CONFIRMED_EMAIL_FOR_STREAM=1

# --- Playback grant signing (long random secret — generate with: openssl rand -hex 32) ---
MEDIA_BRIDGE_GRANT_SECRET=FIXME_GENERATE_LONG_RANDOM_SECRET
STREAM_GRANT_TTL_MS=900000

# --- Resend (optional: welcome email) -----------------------------------------
# RESEND_API_KEY=
# RESEND_FROM=SafeTube <support@safetube.co.il>
# MEDIA_BRIDGE_WELCOME_KEY=FIXME_match_VITE_MEDIA_BRIDGE_WELCOME_KEY

# --- Outbound: direct egress from Germany IP — no proxy -----------------------
OUTBOUND_PROXY_DISABLE=1

# --- yt-dlp tuning ------------------------------------------------------------
YT_DLP_PRIMARY_EXTRACTOR_ARGS=youtube:player_client=tv,web_safari
YT_DLP_BGUTIL_POT_BASE_URL=http://127.0.0.1:4416
YT_DLP_FORMAT=bestvideo[height<=720][ext=mp4]+bestaudio[ext=m4a]/best[height<=720][ext=mp4]/best
# YT_DLP_PLUGIN_DIRS=
# YT_DLP_PER_ATTEMPT_TIMEOUT_MS=30000
# OVERALL_RESOLVE_BUDGET_MS=120000
