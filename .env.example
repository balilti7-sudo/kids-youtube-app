VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_KEY
# אותו ערך משמש לניהול ערוצים (הורה) ולניתוק מכשיר במסך הילד — אפשר להגדיר אחד מהם
VITE_PARENT_MANAGEMENT_PIN=1234
VITE_PARENT_UNLOCK_PIN=1234

# Media Bridge (server/) — origin only (no /api/stream path). Dev: local bridge port; prod: Render URL.
# Example production: https://safetube-media-bridge.onrender.com
# Requests are built as: ${VITE_STREAM_API_BASE}/api/stream/:videoId and /api/media/:videoId
# Local: Vite proxies /api → bridge on 8787. Use the dev server origin (restart Vite after edits).
VITE_STREAM_API_BASE=http://localhost:5174

# Rare: use official YouTube iframe (youtube-nocookie) with modestbranding=1&rel=0 instead of Media Bridge.
# Leave unset/false in production for kids mode (proxied stream has no YouTube UI).
# VITE_YOUTUBE_IFRAME_PLAYER=true

# Redirect target after signup email confirmation.
# Example (local dev): http://localhost:5174/auth?emailVerified=1
# VITE_AUTH_SIGNUP_REDIRECT_TO=

# Optional OAuth callback override (Google, etc). If unset, defaults to:
# ${window.location.origin}/auth?next=/dashboard
# Example (production): https://kids-safe-tube.vercel.app/auth?next=%2Fdashboard
# VITE_AUTH_OAUTH_REDIRECT_TO=
#
# Google sign-in ב-Supabase: Dashboard → Authentication → Providers → הפעילו Google והזינו Client ID/Secret.
# בחלון URL Configuration יש להוסיף לאותיות את כתובת החזרה (Redirect URLs), למשל:
# http://localhost:5174/auth  ואת דומיין ה-production + /auth

# Temporary: show "דילוג על אימות" in forgot parent PIN modal (OAuth path). Remove after resetting PIN.
# VITE_PARENT_PIN_FORGOT_SKIP_VERIFY=1

# Dev-only fallback. Do not set this in production.
# VITE_DEV_DEVICE_OWNER_ID=00000000-0000-0000-0000-000000000000
