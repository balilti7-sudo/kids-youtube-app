VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_KEY
# אותו ערך משמש לניהול ערוצים (הורה) ולניתוק מכשיר במסך הילד — אפשר להגדיר אחד מהם
VITE_PARENT_MANAGEMENT_PIN=1234
VITE_PARENT_UNLOCK_PIN=1234

# Media Bridge (server/) — must match where `npm run dev:api` listens (default port 8787).
# The app does not call YouTube for playback; it uses GET /api/stream and /api/media on this origin.
# If unset, the client defaults to http://localhost:8787. Restart Vite after changes.
VITE_STREAM_API_BASE=http://localhost:8787

# Redirect target after signup email confirmation.
# Example (local dev): http://localhost:5174/auth?emailVerified=1
# VITE_AUTH_SIGNUP_REDIRECT_TO=

# Optional OAuth callback override (Google, etc). If unset, defaults to:
# ${window.location.origin}/auth?next=/dashboard
# Example (production): https://kids-safe-tube.vercel.app/auth?next=%2Fdashboard
# VITE_AUTH_OAUTH_REDIRECT_TO=

# Dev-only fallback. Do not set this in production.
# VITE_DEV_DEVICE_OWNER_ID=00000000-0000-0000-0000-000000000000
