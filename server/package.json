{
  "name": "safetube-media-bridge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Express Media Bridge: Bunny Stream playback with local yt-dlp ingest for YouTube videos",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prestart": "node ensure-ytdlp.cjs --strict",
    "start": "node index.cjs",
    "prestart:worker": "node ensure-ytdlp.cjs --strict",
    "start:worker": "node ingest-worker.cjs",
    "dev": "node --watch index.cjs",
    "dev:worker": "node --watch ingest-worker.cjs",
    "download-tools": "node download-tools.mjs && node ensure-ytdlp.cjs --strict",
    "ensure-ytdlp": "node ensure-ytdlp.cjs --strict"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "axios": "^1.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "resend": "^4.8.0",
    "undici": "^7.8.0",
    "yt-search": "^2.13.1",
    "ytsr": "^3.8.4"
  }
}
