# Port for the Media Bridge (default: 3001 if unset). Render sets PORT automatically.
PORT=3001

# Bind address: 0.0.0.0 = all interfaces (reachable via LAN / public IP). Use 127.0.0.1 to block remote access.
# MEDIA_BRIDGE_HOST=0.0.0.0

# CORS: comma-separated exact origins allowed to call this bridge from the browser (e.g. Vercel + local Vite).
# Default in code includes https://www.safetube.co.il and common localhost dev ports — override to add preview URLs:
# MEDIA_BRIDGE_CORS_ORIGINS=https://www.safetube.co.il,https://safetube.co.il,http://localhost:5173

# Allow any browser Origin (like old `origin: true`). Convenient for dev; avoid on a public-facing home server.
# MEDIA_BRIDGE_CORS_ALLOW_ANY=1

# Legacy: CORS_ORIGIN=* also enables allow-any (same as MEDIA_BRIDGE_CORS_ALLOW_ANY).
# CORS_ORIGIN=

# Comma-separated Piped API base URLs (no trailing slash), tried first. Then pipedapi.lunar.icu +
# api.vkr.dev, then remaining defaults (shuffled). On 403 / rate limit / bad JSON, next instance is used.
# Public instances are unstable—prefer self-hosting for production.
PIPED_API_BASES=https://pipedapi.in.projectsegfau.lt,https://pipedapi.privacyredirect.com,https://pipedapi.tokhmi.xyz

# When behind a reverse proxy with wrong Host, set the public origin for URLs inside HLS manifests
# (e.g. https://media.example.com). Leave unset to derive from each request.
# PUBLIC_BASE_URL=

# Optional: browser User-Agent for Piped + @distube/ytdl-core (defaults to a current Chrome/Windows string)
# BROWSER_USER_AGENT=

# Match yt-dlp to the browser you exported cookies from (Chrome UA recommended).
# Defaults to BROWSER_USER_AGENT if unset.
# YT_DLP_USER_AGENT=Mozilla/5.0 ...

# yt-dlp: primary YouTube InnerTube clients (fewer bot blocks with signed-in cookies).
# YT_DLP_PRIMARY_EXTRACTOR_ARGS=youtube:player_client=ios,android;skip=web_safari

# YouTube: paste browser cookie string for youtube.com (name=value; name2=value2). Used by ytdl and optionally yt-dlp.
# YOUTUBE_COOKIES=
# YTDL_COOKIES=
# Netscape cookies.txt for yt-dlp (`--cookies`). If unset, the bridge uses server/cookies.txt when present,
# then Render secret path, then youtube.com_cookies.txt.
# YOUTUBE_COOKIES_FILE=C:\\path\\to\\cookies.txt

# yt-dlp: max time per CLI attempt (ms). Spawn is killed after this; `--socket-timeout` tracks it in seconds (default 30).
# YT_DLP_PER_ATTEMPT_TIMEOUT_MS=30000

# Total time budget for resolveUpstream (yt-dlp + fallbacks), ms (default 120000 — below frontend 120s cap).
# OVERALL_RESOLVE_BUDGET_MS=120000

# Optional: override yt-dlp binary (default: ./yt-dlp.exe on Windows, ./yt-dlp otherwise — run npm run download-tools)
# YT_DLP_PATH=C:\\path\\to\\yt-dlp.exe
# YT_DLP_ENABLE=1

# Cache resolved upstream URL before re-resolve (ms)
# STREAM_CACHE_TTL_MS=3000000
# SEGMENT_TOKEN_TTL_MS=3600000

# Optional auth gate: require signed-in + confirmed Supabase user for /api/stream.
# Set to 0 to disable this check (not recommended in production).
# REQUIRE_CONFIRMED_EMAIL_FOR_STREAM=1

# Required for email-confirmation checks in the bridge:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Used to sign playback grants for /api/media and /api/segment (set a long random secret in production).
# MEDIA_BRIDGE_GRANT_SECRET=replace-with-long-random-secret
# STREAM_GRANT_TTL_MS=900000

# Optional: YouTube PO token for yt-dlp (see https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide ).
# Value is typically `web.gvs+...` or `mweb.player+...` (full po_token RHS). Still use YOUTUBE_COOKIES_FILE on Render when possible.
# YOUTUBE_PO_TOKEN=web.gvs+YOUR_TOKEN_HERE

# Force direct egress (ignore OUTBOUND_PROXY_URL / HTTPS_PROXY / HTTP_PROXY) — e.g. test without paid proxy / fix HTTP 402 from proxy billing.
# OUTBOUND_PROXY_DISABLE=1
# MEDIA_BRIDGE_DISABLE_OUTBOUND_PROXY=1

# Public origin for HTML email logo URL (no trailing slash). Emails embed GET {PUBLIC_SITE_URL}/logo.png .
# EMAIL_LOGO_URL=https://mysite.example.com/logo.png
# PUBLIC_SITE_URL=https://mysite.example.com
