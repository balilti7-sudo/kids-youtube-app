# Port for the Media Bridge (default: 3001 if unset). Render sets PORT automatically.
PORT=3001

# Bind address: 0.0.0.0 = all interfaces (reachable via LAN / public IP).
# MEDIA_BRIDGE_HOST=0.0.0.0

# CORS: comma-separated exact origins allowed to call this bridge from the browser.
# MEDIA_BRIDGE_CORS_ORIGINS=https://www.safetube.co.il,https://safetube.co.il,http://localhost:5173

# Allow any browser Origin (dev only).
# MEDIA_BRIDGE_CORS_ALLOW_ANY=1

# When behind a reverse proxy, set the public origin for URLs in responses.
# PUBLIC_BASE_URL=https://safetube-media-bridge.onrender.com

# Bunny Stream — playback (transcode + CDN HLS)
# BUNNY_STREAM_API_KEY=your_stream_library_api_key
# BUNNY_LIBRARY_ID=123456
# BUNNY_CDN_HOSTNAME=vz-xxxxx.b-cdn.net
# BUNNY_REQUEST_TIMEOUT_MS=30000
# BUNNY_TRANSCODE_POLL_MS=4000
# BUNNY_TRANSCODE_MAX_MS=600000

# yt-dlp — ingest (resolve direct YouTube media URL for Bunny fetch)
# Run: npm run download-tools  (installs ./yt-dlp, chmod +x, verifies --version)
# prestart runs: node ensure-ytdlp.cjs --strict
#
# YouTube datacenter bypass (no cookies): rotates android_embedded/web_embedded → tv_embedded → ios → android
# YT_DLP_REMOTE_COMPONENTS=ejs:github   # EJS challenge scripts (default)
# YT_DLP_JS_RUNTIMES=node               # Node on Render solves YouTube JS challenges (default)
# YT_DLP_DISABLE_PROFILE_FALLBACK=1     # use only YT_DLP_EXTRACTOR_ARGS / first profile
# YT_DLP_EXTRACTOR_ARGS=youtube:player_client=android_embedded,web_embedded
# YT_DLP_BINARY_PATH=./yt-dlp
# YT_DLP_TIMEOUT_MS=90000
# YT_DLP_LONG_TIMEOUT_MS=300000
# LONG_VIDEO_DURATION_SEC=65
# YT_DLP_FORMAT=best[height<=360][ext=mp4]/best[height<=360]/18/best[ext=mp4]/best
# YT_DLP_COOKIES_FILE=./youtube_cookies.txt
# YT_DLP_EXTRACTOR_ARGS=youtubepot-bgutilhttp:base_url=http://127.0.0.1:4416
# YT_DLP_PLUGIN_DIRS=./yt-dlp-plugins
# Proxy for yt-dlp — Webshare rotating/backconnect (set once on Render; no IP management).
# Option A — full URL (%40 = @ if dashboard strips @):
# YT_DLP_PROXY=http://YOUR_USER-rotate:YOUR_PASSWORD@p.webshare.io:80
# Option B — components (recommended on Render; avoids @ corruption):
# YT_DLP_PROXY_SCHEME=http
# YT_DLP_PROXY_USER=YOUR_USER-rotate
# YT_DLP_PROXY_PASSWORD=YOUR_PASSWORD
# YT_DLP_PROXY_HOST=p.webshare.io
# YT_DLP_PROXY_PORT=80
# Auto-retry on YouTube bot block / yt-dlp exit 152 (new IP each attempt):
# YT_DLP_PROXY_MAX_RETRIES=4
# YT_DLP_PROXY_RETRY_DELAY_MS=1200
# BROWSER_USER_AGENT=

# Cache resolved Bunny playback URL before re-resolve (ms)
# RESOLVE_CACHE_TTL_MS=480000
# STREAM_PREPARE_TTL_MS=300000
# ASYNC_STREAM_QUICK_READY_MS=2500
# MEDIA_PROXY_TIMEOUT_MS=90000

# Supabase (auth + email flows)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Resend + forgot-PIN / pairing emails
# RESEND_API_KEY=re_...
# MEDIA_BRIDGE_WELCOME_KEY=your-long-random-secret
# RESEND_FROM=SafeTube <support@safetube.co.il>

# Playback grant signing (optional legacy /api/media proxy)
# MEDIA_BRIDGE_GRANT_SECRET=replace-with-long-random-secret
# STREAM_GRANT_TTL_MS=900000

# PUBLIC_SITE_URL=https://www.safetube.co.il
